{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "ThreatLog": {
      "title": "Threat Log",
      "description": "A record of a detected security threat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who performed the scan." },
        "type": { "type": "string", "description": "The type of scan (phishing, url, logs, code, deepfake)." },
        "threat": { "type": "string", "description": "The name of the detected threat." },
        "risk_level": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "confidence": { "type": "number", "description": "AI confidence score." },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "threat", "risk_level", "confidence", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user the notification is for." },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "error", "success"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "timestamp"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback, bug reports, or feature requests.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "type": { "type": "string", "enum": ["bug", "feature", "other"] },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "in-progress", "resolved"] }
      },
      "required": ["userId", "userEmail", "type", "subject", "message", "timestamp", "status"]
    }
  },
  "firestore": {
    "/threat_history/{logId}": {
      "schema": "ThreatLog",
      "description": "Collection of security threat logs."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user notifications."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of user feedback."
    }
  }
}
